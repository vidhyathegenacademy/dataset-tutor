# Direct OpenAI provider. Users can also enter keys in AI mode at runtime.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional OpenAI-compatible provider, such as an internal proxy or another gateway.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# Optional Lovable fallback
LOVABLE_API_KEY=
LOVABLE_MODEL=google/gemini-3-flash-preview
